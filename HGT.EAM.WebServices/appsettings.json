{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "EAMBaseUrl": "",
    "EAMCredentials": [
        {
            "Username": "",
            "Password": "",
            "Organization": ""
        }
    ],
    "EAMGrids": [
        {
            "GridName": "",
            "UserFunction": "",
            "GridId": 0,
            "DataSpyIds": {
                "Day": 0,
                "Month": 0,
                "Year": 0
            },
            "NumberRecordsFirstReturned": 20000,
            "CursorPosition": 0,
            "HGTGridType": "0",
            "HGTGridName": "0"
        }
    ],
    "EnableAuthScheme": false,
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": "Verbose",
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs\\Serilog..log",
                    "rollingInterval": "Day"
                }
            }
        ],
        "Properties": {
            "Application": "SerilogVSNlog"
        }
    },
    "AllowedHosts": "*"
}
