{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "GridCache": "Data Source=gridcache.db"
  },
  "EAMBaseUrl": "",
  "EAMCredentials": [
    {
      "Username": "",
      "Password": "",
      "Organization": ""
    }
  ],
  "EAMGrids": [
    {
      "GridName": "",
      "UserFunction": "",
      "GridId": 0,
      "DataSpyIds": {
        "PreviousDay": 0,
        "PreviousMonth": 0,
        "CurrentMonth": 0,
        "LastYear": 0,
        "Custom": 0,
        "AllRecords": 0
      },
      "NumberRecordsFirstReturned": 0,
      "CursorPosition": 0,
      "HGTGridType": 0,
      "HGTGridName": 0,
      "FilterField": ""
    }
  ],
  "EAMDefaultRecords": 0,
  "EnableAuthScheme": false,
  "ApiTitle": "HGT - Grid API",
  "ApiDescription": "API REST para acceder a las grillas de EAM de HGT. Internamente consume los servicios SOAP de EAM.",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.MSSqlServer" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Filter": [
      {
        "Name": "ByIncludingOnly",
        "Args": {
          "expression": "Contains(RequestPath, '/api') or @Level = 'Error'"
        }
      }
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Properties": {
      "Application": "SerilogVSNlog"
    }
  },
  "AllowedHosts": "*",
  "GridCache": {
    "Enabled": true,
    "ExpirationMinutes": 60
  }
}
