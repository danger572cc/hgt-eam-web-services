<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config base del proyecto HGT.EAM.WebServices.

  IMPORTANTE: El placeholder $(EnvironmentName) es reemplazado automáticamente
  por MSBuild durante el publish según el perfil seleccionado:
    - PublishQAS  / IISProfileQAS  → Development
    - PublishPROD / IISProfilePROD → Production / Stage

  NO editar manualmente el valor de ASPNETCORE_ENVIRONMENT en este archivo;
  hacerlo en el perfil .pubxml correspondiente (<EnvironmentName>...</>).
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*"
           modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>

    <!--
      requestTimeout: tiempo máximo que IIS espera al proceso ASP.NET Core.
      10 minutos cubre los fetches más largos desde EAM (65K+ registros).
    -->
    <aspNetCore processPath="%LAUNCHER_PATH%"
                arguments="%LAUNCHER_ARGS%"
                stdoutLogEnabled="false"
                stdoutLogFile=".\logs\stdout"
                hostingModel="inprocess"
                requestTimeout="00:30:00">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="$(EnvironmentName)" />
      </environmentVariables>
    </aspNetCore>

    <!-- Compresión dinámica para reducir payload de respuestas JSON -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
  </system.webServer>
</configuration>
